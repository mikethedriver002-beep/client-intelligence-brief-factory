{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Brief Factory Client Config",
  "type": "object",
  "required": ["agency_id", "agency_name", "client_id", "client_name", "vertical"],
  "properties": {
    "schema": {"type": "string"},
    "agency_id": {"type": "string"},
    "agency_name": {"type": "string"},
    "client_id": {"type": "string"},
    "client_name": {"type": "string"},
    "vertical": {"type": "string"},
    "brief_period_label": {"type": "string"},
    "timezone": {"type": "string"},
    "watch_keywords": {"type": "array", "items": {"type": "string"}},
    "competitors": {"type": "array", "items": {"type": "string"}},
    "service_areas": {"type": "array", "items": {"type": "string"}},
    "quality": {
      "type": "object",
      "properties": {
        "minimum_items": {"type": "integer", "minimum": 1},
        "top_count": {"type": "integer", "minimum": 1}
      }
    },
    "delivery": {
      "type": "object",
      "properties": {
        "cadence": {"type": "string"},
        "format": {"type": "array", "items": {"type": "string"}},
        "human_review_required": {"type": "boolean"},
        "human_review_complete": {"type": "boolean"},
        "review_status": {"type": "string"}
      }
    },
    "approval": {
      "type": "object",
      "properties": {
        "human_review_required": {"type": "boolean"},
        "human_review_complete": {"type": "boolean"},
        "review_status": {"type": "string"},
        "reviewer": {"type": "string"}
      }
    }
  }
}
